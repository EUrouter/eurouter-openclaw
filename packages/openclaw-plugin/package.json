{
  "name": "@eurouter/openclaw-eurouter",
  "version": "0.1.5",
  "description": "EUrouter provider plugin for OpenClaw — EU-hosted, GDPR-compliant LLM routing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "openclaw.plugin.json", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "update-models": "npx tsx scripts/update-static-models.ts"
  },
  "homepage": "https://github.com/EUrouter/eurouter-openclaw",
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "providers": ["eurouter"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  },
  "devDependencies": {
    "openclaw": "2026.3.24-beta.2",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "keywords": ["openclaw", "openclaw-plugin", "eurouter", "llm", "gdpr", "eu-data-residency"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EUrouter/eurouter-openclaw.git"
  }
}
